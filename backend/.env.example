# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/portfolio?retryWrites=true&w=majority

# Backend Port
PORT=5000

# Nodemailer Settings (Gmail notification to divyanshutiwari500@gmail.com)
# Setup a Gmail App Password: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_gmail_username@gmail.com
EMAIL_PASS=your_gmail_app_password

# Receiver email (where portfolio messages will be forwarded)
RECEIVER_EMAIL=divyanshutiwari500@gmail.com

# Mode (development or production)
NODE_ENV=development
